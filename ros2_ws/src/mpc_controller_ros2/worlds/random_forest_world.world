<?xml version="1.0" ?>
<!--
  Random Forest World (20m×20m)
  12개 원기둥 장애물 랜덤 배치 (반지름 0.2~0.5m)

  레이아웃 (top-down):
  ┌──────────────────────────────────────┐
  │ S(0,0)                               │
  │     ○(2,6)     ○(-3,8)              │
  │  ○(-6,4)           ○(5,5)           │
  │        ○(0,2)                        │
  │  ○(-7,-1)    ○(3,0)    ○(7,1)      │
  │                                      │
  │     ○(-4,-4)     ○(6,-3)            │
  │  ○(-2,-6)              ○(4,-6)      │
  │                              G(7,−7) │
  └──────────────────────────────────────┘
-->
<sdf version="1.8">
  <world name="random_forest_world">
    <!-- Physics -->
    <physics name="1ms" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>
    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>

    <!-- Light -->
    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <!-- Ground Plane -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry><plane><normal>0 0 1</normal><size>100 100</size></plane></geometry>
        </collision>
        <visual name="visual">
          <geometry><plane><normal>0 0 1</normal><size>100 100</size></plane></geometry>
          <material>
            <ambient>0.7 0.75 0.65 1</ambient>
            <diffuse>0.7 0.75 0.65 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- ==================== OUTER WALLS (20m×20m) ==================== -->
    <model name="wall_north">
      <static>true</static>
      <pose>0 10 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>20.4 0.2 1.0</size></box></geometry></collision>
        <visual name="visual">
          <geometry><box><size>20.4 0.2 1.0</size></box></geometry>
          <material><ambient>0.5 0.5 0.5 1</ambient><diffuse>0.5 0.5 0.5 1</diffuse></material>
        </visual>
      </link>
    </model>
    <model name="wall_south">
      <static>true</static>
      <pose>0 -10 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>20.4 0.2 1.0</size></box></geometry></collision>
        <visual name="visual">
          <geometry><box><size>20.4 0.2 1.0</size></box></geometry>
          <material><ambient>0.5 0.5 0.5 1</ambient><diffuse>0.5 0.5 0.5 1</diffuse></material>
        </visual>
      </link>
    </model>
    <model name="wall_east">
      <static>true</static>
      <pose>10 0 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>0.2 20.0 1.0</size></box></geometry></collision>
        <visual name="visual">
          <geometry><box><size>0.2 20.0 1.0</size></box></geometry>
          <material><ambient>0.5 0.5 0.5 1</ambient><diffuse>0.5 0.5 0.5 1</diffuse></material>
        </visual>
      </link>
    </model>
    <model name="wall_west">
      <static>true</static>
      <pose>-10 0 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>0.2 20.0 1.0</size></box></geometry></collision>
        <visual name="visual">
          <geometry><box><size>0.2 20.0 1.0</size></box></geometry>
          <material><ambient>0.5 0.5 0.5 1</ambient><diffuse>0.5 0.5 0.5 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- ==================== TREE OBSTACLES (12 cylinders) ==================== -->
    <!-- 원기둥 "나무" 장애물, 다양한 반지름 (0.2~0.5m) -->
    <!-- 스폰 위치 (0,0) 주변 2m 이내는 비워둠 -->

    <model name="tree_01">
      <static>true</static>
      <pose>2 6 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><cylinder><radius>0.35</radius><length>1.0</length></cylinder></geometry></collision>
        <visual name="visual">
          <geometry><cylinder><radius>0.35</radius><length>1.0</length></cylinder></geometry>
          <material><ambient>0.4 0.25 0.1 1</ambient><diffuse>0.4 0.25 0.1 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="tree_02">
      <static>true</static>
      <pose>-3 8 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><cylinder><radius>0.4</radius><length>1.0</length></cylinder></geometry></collision>
        <visual name="visual">
          <geometry><cylinder><radius>0.4</radius><length>1.0</length></cylinder></geometry>
          <material><ambient>0.35 0.2 0.1 1</ambient><diffuse>0.35 0.2 0.1 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="tree_03">
      <static>true</static>
      <pose>-6 4 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><cylinder><radius>0.3</radius><length>1.0</length></cylinder></geometry></collision>
        <visual name="visual">
          <geometry><cylinder><radius>0.3</radius><length>1.0</length></cylinder></geometry>
          <material><ambient>0.45 0.3 0.15 1</ambient><diffuse>0.45 0.3 0.15 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="tree_04">
      <static>true</static>
      <pose>5 5 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><cylinder><radius>0.5</radius><length>1.0</length></cylinder></geometry></collision>
        <visual name="visual">
          <geometry><cylinder><radius>0.5</radius><length>1.0</length></cylinder></geometry>
          <material><ambient>0.3 0.18 0.08 1</ambient><diffuse>0.3 0.18 0.08 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="tree_05">
      <static>true</static>
      <pose>0 2.5 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><cylinder><radius>0.25</radius><length>1.0</length></cylinder></geometry></collision>
        <visual name="visual">
          <geometry><cylinder><radius>0.25</radius><length>1.0</length></cylinder></geometry>
          <material><ambient>0.5 0.3 0.15 1</ambient><diffuse>0.5 0.3 0.15 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="tree_06">
      <static>true</static>
      <pose>-7 -1 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><cylinder><radius>0.4</radius><length>1.0</length></cylinder></geometry></collision>
        <visual name="visual">
          <geometry><cylinder><radius>0.4</radius><length>1.0</length></cylinder></geometry>
          <material><ambient>0.38 0.22 0.1 1</ambient><diffuse>0.38 0.22 0.1 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="tree_07">
      <static>true</static>
      <pose>3 0 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><cylinder><radius>0.3</radius><length>1.0</length></cylinder></geometry></collision>
        <visual name="visual">
          <geometry><cylinder><radius>0.3</radius><length>1.0</length></cylinder></geometry>
          <material><ambient>0.42 0.26 0.12 1</ambient><diffuse>0.42 0.26 0.12 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="tree_08">
      <static>true</static>
      <pose>7 1 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><cylinder><radius>0.2</radius><length>1.0</length></cylinder></geometry></collision>
        <visual name="visual">
          <geometry><cylinder><radius>0.2</radius><length>1.0</length></cylinder></geometry>
          <material><ambient>0.48 0.28 0.14 1</ambient><diffuse>0.48 0.28 0.14 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="tree_09">
      <static>true</static>
      <pose>-4 -4 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><cylinder><radius>0.45</radius><length>1.0</length></cylinder></geometry></collision>
        <visual name="visual">
          <geometry><cylinder><radius>0.45</radius><length>1.0</length></cylinder></geometry>
          <material><ambient>0.32 0.2 0.1 1</ambient><diffuse>0.32 0.2 0.1 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="tree_10">
      <static>true</static>
      <pose>6 -3 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><cylinder><radius>0.35</radius><length>1.0</length></cylinder></geometry></collision>
        <visual name="visual">
          <geometry><cylinder><radius>0.35</radius><length>1.0</length></cylinder></geometry>
          <material><ambient>0.44 0.28 0.12 1</ambient><diffuse>0.44 0.28 0.12 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="tree_11">
      <static>true</static>
      <pose>-2 -6 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><cylinder><radius>0.3</radius><length>1.0</length></cylinder></geometry></collision>
        <visual name="visual">
          <geometry><cylinder><radius>0.3</radius><length>1.0</length></cylinder></geometry>
          <material><ambient>0.36 0.22 0.1 1</ambient><diffuse>0.36 0.22 0.1 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="tree_12">
      <static>true</static>
      <pose>4 -6 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><cylinder><radius>0.25</radius><length>1.0</length></cylinder></geometry></collision>
        <visual name="visual">
          <geometry><cylinder><radius>0.25</radius><length>1.0</length></cylinder></geometry>
          <material><ambient>0.5 0.32 0.16 1</ambient><diffuse>0.5 0.32 0.16 1</diffuse></material>
        </visual>
      </link>
    </model>

  </world>
</sdf>
